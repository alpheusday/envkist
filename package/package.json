{
    "name": "envkist",
    "version": "0.2.0",
    "description": "A utility to defer the resolution of environment variables",
    "keywords": [
        "envkist",
        "env",
        "defer",
        "resolution",
        "ts",
        "typescript",
        "js",
        "javascript"
    ],
    "homepage": "https://github.com/alpheusday/envkist",
    "bugs": "https://github.com/alpheusday/envkist/issues",
    "repository": {
        "type": "git",
        "url": "https://github.com/alpheusday/envkist.git",
        "directory": "package"
    },
    "license": "MIT",
    "author": {
        "name": "Alpheus",
        "email": "contact@alphe.us"
    },
    "exports": {
        ".": {
            "types": "./dist/node.d.ts",
            "deno": "./dist/deno.mjs",
            "bun": "./dist/bun.mjs",
            "workerd": "./dist/cloudflare.mjs",
            "browser": "./dist/browser.mjs",
            "import": "./dist/node.mjs",
            "require": "./dist/node.js"
        },
        "./internal/*": {
            "types": "./dist/*.d.ts",
            "import": "./dist/*.mjs",
            "require": "./dist/*.js"
        },
        "./package.json": "./package.json"
    },
    "main": "./dist/node.js",
    "module": "./dist/node.mjs",
    "types": "./dist/node.d.ts",
    "files": [
        "dist"
    ]
}
